          }
        }
      }
    },
    "cleanup.level.cleanPolish.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clean up + polish"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清理 + 润色"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清理 + 潤色"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーンアップ + 推敲"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정리 + 다듬기"
          }
        }
      }
    },
    "cleanup.level.lightEdit.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Polish + light edit"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "润色 + 轻微编辑"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "潤色 + 輕微編輯"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "推敲 + 軽い編集"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다듬기 + 가벼운 편집"
          }
        }
      }
    },
    "cleanup.level.raw.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Output the Whisper result directly, without calling the LLM."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接输出 Whisper 结果，不调用 LLM。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接輸出 Whisper 結果，不呼叫 LLM。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Whisper の結果をそのまま出力し、LLM は呼び出しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LLM을 호출하지 않고 Whisper 결과를 그대로 출력합니다."
          }
        }
      }
    },
    "cleanup.level.fixOnly.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fix punctuation, casing, homophones, and proper nouns/terminology; keep every word and the original wording."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修正标点、大小写、同音词、专有名词/术语；保留全部词语与原始措辞。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "修正標點、大小寫、同音詞、專有名詞/術語；保留全部詞語與原始措辭。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "句読点、大文字小文字、同音語、固有名詞・専門用語を修正します。すべての語と元の言い回しを保持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구두점, 대소문자, 동음이의어, 고유명사/용어를 수정합니다. 모든 단어와 원래 표현을 유지합니다."
          }
        }
      }
    },
    "cleanup.level.cleanPolish.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On top of \"Fix only\", remove filler words/stutters, fix grammar, and add paragraph breaks; the meaning is fully preserved."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在「仅修正」基础上删除填充词/口吃、修正语法、添加段落分隔；意思完整保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「僅修正」基礎上刪除填充詞/口吃、修正語法、新增段落分隔；意思完整保留。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「修正のみ」に加えて、フィラー語・どもりを削除し、文法を修正し、段落区切りを追加します。意味は完全に保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "「수정만」에 더해 군더더기 표현/말더듬을 제거하고 문법을 수정하며 문단 구분을 추가합니다. 의미는 온전히 유지됩니다."
          }
        }
      }
    },
    "cleanup.level.lightEdit.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On top of \"Clean up + polish\", lightly condense/reorder to improve readability (applies to TXT only; SRT keeps L2 semantics to ensure the timeline stays correct)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在「清理 + 润色」基础上轻微精简/重排以提升可读性（仅作用于 TXT；SRT 仍保持 L2 语义，确保时间轴正确）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「清理 + 潤色」基礎上輕微精簡/重排以提升可讀性（僅作用於 TXT；SRT 仍保持 L2 語義，確保時間軸正確）。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「クリーンアップ + 推敲」に加えて、読みやすさを高めるために軽く要約・並べ替えを行います（TXT のみに適用。SRT は L2 のセマンティクスを維持し、タイムラインが正しく保たれます）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "「정리 + 다듬기」에 더해 가독성을 높이기 위해 가볍게 요약/재배치합니다(TXT에만 적용. SRT는 L2 의미를 유지하여 타임라인이 올바르게 유지됩니다)."
          }
        }
      }
    },
    "error.noAudioTrack": {
