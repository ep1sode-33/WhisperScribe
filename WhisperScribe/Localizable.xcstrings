          "stringUnit": {
            "state": "translated",
            "value": "Raw (no LLM)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "原始（不经过 LLM）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "原始（不經過 LLM）"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのまま（LLM なし）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원본(LLM 미사용)"
          }
        }
      }
    },
    "cleanup.level.fixOnly.title": {
